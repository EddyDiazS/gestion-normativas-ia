# .env.example — PrototipoChatNextJs
# Copiar este archivo como .env.local para desarrollo:
#   cp .env.example .env.local
#
# Luego toca rellenar cada variable con tus valores reales.
# No subir .env.local al repositorio.
# Entorno (local o production)
APP_ENV=local

# Base de datos Oracle
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_SERVICE=

ORACLE_CLIENT_PATH=

# Google Gemini API
GOOGLE_API_KEY=

# URL del agente académico
ACADEMIC_AGENT_URL=http://127.0.0.1:8001

# Ruta de documentos normativos
DATA_PATH=data/normativas