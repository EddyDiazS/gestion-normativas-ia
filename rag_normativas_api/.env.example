
# .env.example — PrototipoChatNextJs
# Copiar este archivo como .env.local para desarrollo:
#   cp .env.example .env.local
#
# Luego toca rellenar cada variable con tus valores reales.
# No subir .env.local al repositorio.

APP_ENV=local

# ── Google Gemini ─────────────────────────────────────────────
GOOGLE_API_KEY= # Tu API Key de Google Cloud con acceso a Gemini

# ── Documentos normativos ─────────────────────────────────────
DATA_PATH=data/normativas

# ── Oracle Database ───────────────────────────────────────────
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=1521
DB_SERVICE=

# Ruta al cliente Oracle instalado en tu máquina
# Ejemplo Windows: C:/oracle/instantclient_21_3
# Ejemplo Linux:   /opt/oracle/instantclient_21_3
ORACLE_CLIENT_PATH=
